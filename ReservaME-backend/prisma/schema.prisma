generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String                 @id @default(uuid())
  name            String
  domain          String?                @unique
  email           String?
  address         String?
  isActive        Boolean                @default(true) @map("is_active")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  instagramUrl    String?                @map("instagram_url")
  appSetting      AppSetting?
  barberServices  BarberService[]
  weeklySchedules BarberWeeklySchedule[]
  barberTimeBlocks BarberTimeBlock[]
  barbers         Barber[]
  portfolioImages PortfolioImage[]
  productos       Producto[]
  reservations    Reservation[]
  reviews         Review[]
  services        Service[]
  settings        TenantSettings?
  tokens          Token[]
  users           User[]

  @@map("tenants")
}

model TenantSettings {
  id             String   @id @default(uuid())
  tenantId       String   @unique @map("tenant_id")
  logoUrl        String?  @map("logo_url")
  heroImageUrl   String?  @map("hero_image_url")
  primaryColor   String?  @map("primary_color")
  secondaryColor String?  @map("secondary_color")
  headerColor    String?  @map("header_color")
  footerColor    String?  @map("footer_color")
  fontFamily     String?  @map("font_family")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  email        String   @unique
  passwordHash String?  @map("password_hash")
  role         UserRole
  isActive     Boolean  @default(false) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  barber       Barber?
  tokens       Token[]
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Barber {
  id              String                 @id @default(uuid())
  tenantId        String                 @map("tenant_id")
  userId          String?                @unique @map("user_id")
  name            String
  slug            String
  bio             String?
  phone           String?
  photoUrl        String?                @map("photo_url")
  isActive        Boolean                @default(true) @map("is_active")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  services        BarberService[]
  weeklySchedule  BarberWeeklySchedule[]
  timeBlocks      BarberTimeBlock[]
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?                  @relation(fields: [userId], references: [id])
  portfolioImages PortfolioImage[]
  reservations    Reservation[]
  reviews         Review[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
  @@map("barbers")
}

model Service {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  name            String
  description     String?
  basePrice       Decimal?        @map("base_price")
  baseDurationMin Int?            @map("base_duration_min")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  barberServices  BarberService[]
  reservations    Reservation[]
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("services")
}

model BarberService {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  barberId     String        @map("barber_id")
  serviceId    String        @map("service_id")
  price        Decimal
  durationMin  Int           @map("duration_min")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  barber       Barber        @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([barberId, serviceId])
  @@index([tenantId])
  @@index([barberId])
  @@index([serviceId])
  @@map("barber_services")
}

model Reservation {
  id               String            @id @default(uuid())
  tenantId         String            @map("tenant_id")
  barberId         String            @map("barber_id")
  serviceId        String            @map("service_id")
  barberServiceId  String            @map("barber_service_id")
  comment          String?           @map("comment") @db.VarChar(500)
  clientName       String            @map("client_name")
  clientPhone      String            @map("client_phone")
  clientEmail      String            @map("client_email")
  startAt          DateTime          @map("start_at")
  endAt            DateTime          @map("end_at")
  status           ReservationStatus
  canceledAt       DateTime?         @map("canceled_at")
  completedAt      DateTime?         @map("completed_at")
  reminderSentAt   DateTime?         @map("reminder_sent_at")
  priceFinal       Decimal           @map("price_final")
  durationFinalMin Int               @map("duration_final_min")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  barber           Barber            @relation(fields: [barberId], references: [id])
  barberService    BarberService     @relation(fields: [barberServiceId], references: [id])
  service          Service           @relation(fields: [serviceId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  review           Review?
  tokens           Token[]

  @@index([tenantId])
  @@index([barberId, startAt])
  @@index([status])
  @@map("reservations")
}

model AppSetting {
  id                      String   @id @default(uuid())
  tenantId                String   @unique @map("tenant_id")
  reminderHoursBefore     Int      @default(24) @map("reminder_hours_before")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  cancellationHoursBefore Int      @default(3) @map("cancellation_hours_before")
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("app_settings")
}

model PortfolioImage {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  barberId      String   @map("barber_id")
  imageUrl      String   @map("image_url")
  position      Int      @default(0)
  visible       Boolean  @default(true)
  hiddenByAdmin Boolean  @default(false) @map("hidden_by_admin")
  hiddenReason  String?  @map("hidden_reason")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  barber        Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([barberId, position])
  @@map("portfolio_images")
}

model Review {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  reservationId String      @unique @map("reservation_id")
  barberId      String      @map("barber_id")
  rating        Int
  comment       String?
  visible       Boolean     @default(true)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  barber        Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([barberId])
  @@map("reviews")
}

model Token {
  id            String       @id @default(uuid())
  tenantId      String?      @map("tenant_id")
  type          TokenType
  tokenHash     String       @unique @map("token_hash")
  userId        String?      @map("user_id")
  reservationId String?      @map("reservation_id")
  expiresAt     DateTime     @map("expires_at")
  usedAt        DateTime?    @map("used_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tenant        Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([expiresAt])
  @@map("tokens")
}

model BarberWeeklySchedule {
  id       String    @id @default(uuid())
  tenantId String    @map("tenant_id")
  barberId String    @map("barber_id")
  day      DayOfWeek
  isClosed Boolean   @default(false) @map("is_closed")
  startMin Int       @default(600) @map("start_min")
  endMin   Int       @default(1200) @map("end_min")
  barber   Barber    @relation(fields: [barberId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([barberId, day])
  @@index([tenantId])
  @@index([barberId])
  @@map("barber_weekly_schedule")
}

model BarberTimeBlock {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  barberId  String   @map("barber_id")

  startAt   DateTime @map("start_at")
  endAt     DateTime @map("end_at")

  reason    String?
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, barberId, startAt])
  @@index([tenantId])
  @@index([barberId])
  @@index([tenantId, barberId, startAt, endAt])
  @@map("barber_time_blocks")
}

model Producto {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  nombre      String
  descripcion String?
  precio      Int
  stock       Int      @default(0)
  imagenUrl   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("productos")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  BARBERO
}

enum ReservationStatus {
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

enum TokenType {
  ACTIVACION_CUENTA
  GESTION_RESERVA
  RESENA
  RECUPERAR_PASSWORD
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}
