// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BARBERO
}

enum ReservationStatus {
  CONFIRMADA
  CANCELADA
  COMPLETADA
}

enum TokenType {
  ACTIVACION_CUENTA
  GESTION_RESERVA
  RESENA
  RECUPERAR_PASSWORD
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  role         UserRole
  isActive     Boolean  @default(false) @map("is_active")

  barber Barber?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tokens Token[]

  @@map("users")
}

model Barber {
  id       String  @id @default(uuid())
  userId   String? @unique @map("user_id")
  name     String
  linkSetmore String
  slug     String  @unique
  bio      String?
  phone    String?
  photoUrl String? @map("photo_url")
  isActive Boolean @default(true) @map("is_active")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  services        BarberService[]
  reservations    Reservation[]
  portfolioImages PortfolioImage[]
  reviews         Review[]
  weeklySchedule  BarberWeeklySchedule[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("barbers")
}

model Service {
  id              String   @id @default(uuid())
  name            String
  description     String?
  basePrice       Decimal? @map("base_price")
  baseDurationMin Int?     @map("base_duration_min")
  isActive        Boolean  @default(true) @map("is_active")

  barberServices BarberService[]
  reservations   Reservation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("services")
}

model BarberService {
  id          String  @id @default(uuid())
  barberId    String  @map("barber_id")
  serviceId   String  @map("service_id")
  price       Decimal
  durationMin Int     @map("duration_min")
  isActive    Boolean @default(true) @map("is_active")

  barber  Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  reservations Reservation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([barberId, serviceId])
  @@index([barberId])
  @@index([serviceId])
  @@map("barber_services")
}

model Reservation {
  id              String @id @default(uuid())
  barberId        String @map("barber_id")
  serviceId       String @map("service_id")
  barberServiceId String @map("barber_service_id")
  comment         String? @db.VarChar(500) @map("comment") 


  clientName  String @map("client_name")
  clientPhone String @map("client_phone")
  clientEmail String @map("client_email")

  startAt DateTime @map("start_at")
  endAt   DateTime @map("end_at")

  status      ReservationStatus
  canceledAt  DateTime?         @map("canceled_at")
  completedAt DateTime?         @map("completed_at")

  reminderSentAt DateTime? @map("reminder_sent_at")

  priceFinal       Decimal @map("price_final")
  durationFinalMin Int     @map("duration_final_min")

  barber        Barber        @relation(fields: [barberId], references: [id], onDelete: Restrict)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  barberService BarberService @relation(fields: [barberServiceId], references: [id], onDelete: Restrict)

  review Review?
  tokens Token[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([barberId, startAt])
  @@index([status])
  @@map("reservations")
}

model AppSetting {
  id                  Int      @id @default(1)
  reminderHoursBefore Int      @default(24) @map("reminder_hours_before")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model PortfolioImage {
  id            String  @id @default(uuid())
  barberId      String  @map("barber_id")
  imageUrl      String  @map("image_url")
  position      Int     @default(0)
  visible       Boolean @default(true)
  hiddenByAdmin Boolean @default(false) @map("hidden_by_admin")
  hiddenReason  String? @map("hidden_reason")

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([barberId, position])
  @@map("portfolio_images")
}

model Review {
  id            String  @id @default(uuid())
  reservationId String  @unique @map("reservation_id")
  barberId      String  @map("barber_id")
  rating        Int
  comment       String?
  visible       Boolean @default(true)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  barber      Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([barberId])
  @@map("reviews")
}

model Token {
  id        String    @id @default(uuid())
  type      TokenType
  tokenHash String    @unique @map("token_hash")

  userId        String? @map("user_id")
  reservationId String? @map("reservation_id")

  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([expiresAt])
  @@map("tokens")
}

model BarberWeeklySchedule {
  id       String    @id @default(uuid())
  barberId String    @map("barber_id")
  day      DayOfWeek
  isClosed Boolean   @default(false) @map("is_closed")
  startMin Int       @default(600) @map("start_min") // 10:00
  endMin   Int       @default(1200) @map("end_min") // 20:00

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, day])
  @@index([barberId])
  @@map("barber_weekly_schedule")
}


// Modelo que representa los productos a la venta en la barbería
model Producto {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  precio      Int
  stock       Int      @default(0)
  imagenUrl   String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}